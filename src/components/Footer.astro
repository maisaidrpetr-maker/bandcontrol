---
/* src/components/Footer.astro */
---

<footer class="rack-footer">
    <div class="footer-texture"></div>
    
    <div class="footer-content">
        <div class="status-group">
            <span class="footer-text">
                BandControl v. 0.1 - Generated by Astro framework - Petr Maišaidr © 2026 - All rights reserved.
            </span>
        </div>
    </div>

    <div class="rivet left"></div>
    <div class="rivet right"></div>
</footer>

<style>
    .rack-footer {
        position: relative;
        width: 100%;
        background: linear-gradient(180deg, #1a1a1a 0%, #0a0a0a 100%);
        padding: 20px 0;
        border-top: 2px solid #333;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0 -10px 30px rgba(0,0,0,0.8);
        overflow: hidden;
        margin-top: auto; /* Tlačí patičku dospod, pokud je málo obsahu */
    }

    .footer-texture {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,255,255,0.01) 3px);
        pointer-events: none;
    }

    .footer-content {
        z-index: 1;
    }

    .status-group {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .footer-text {
        color: #444;
        font-family: 'Orbitron', sans-serif;
        font-size: 11px;
        letter-spacing: 2px;
        text-transform: uppercase;
        transition: color 0.3s ease;
    }

    /* Industriální nýty */
    .rivet {
        width: 14px;
        height: 14px;
        background: radial-gradient(circle at 35% 35%, #444 0%, #222 40%, #000 100%);
        border-radius: 50%;
        border: 1px solid #111;
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        box-shadow: inset 0 1px 1px rgba(255,255,255,0.1), 0 2px 4px rgba(0,0,0,0.5);
    }
    .rivet.left { left: 30px; }
    .rivet.right { right: 30px; }

    .rack-footer:hover .footer-text {
        color: #666;
    }

    /* Optimalizace pro mobilní zobrazení */
    @media (max-width: 768px) {
        .footer-text { font-size: 9px; letter-spacing: 1px; text-align: center; }
        .rivet { display: none; } /* Na mobilu nýty schováme, aby nezavazely textu */
    }
</style>