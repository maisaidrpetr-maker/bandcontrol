---
// src/components/MetalModule.astro
const { title } = Astro.props;
---

<section class="metal-module">
  <span class="rivet top-left"></span>
  <span class="rivet top-right"></span>
  <span class="rivet bottom-left"></span>
  <span class="rivet bottom-right"></span>

  {title && <header class="module-header">
    <h3>{title}</h3>
  </header>}

  <div class="module-content">
    <slot /> </div>
</section>

<style>
  .metal-module {
    background: radial-gradient(circle at 50% 0%, #333 0%, #1a1a1a 100%);
    border: 1px solid #000;
    border-top: 1px solid #777; /* Horní odlesk hrany */
    border-radius: 8px;
    position: relative;
    padding: 25px;
    margin: 20px;
    box-shadow: 
      0 10px 20px rgba(0,0,0,0.5),
      inset 0 1px 2px rgba(255,255,255,0.1);
    color: #ccc;
  }

  .module-header h3 {
    font-family: 'Arial Black', sans-serif;
    text-transform: uppercase;
    font-size: 1.2rem;
    margin-bottom: 15px;
    background: linear-gradient(180deg, #fff 0%, #888 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    border-bottom: 1px solid #333;
    display: inline-block;
    padding-bottom: 5px;
  }

  .module-content {
    font-family: 'Segoe UI', sans-serif;
  }

  /* NÝTY (přesně ty tvoje) */
  .rivet {
    width: 10px;
    height: 10px;
    background: radial-gradient(circle at 35% 35%, #666 0%, #111 100%);
    border-radius: 50%;
    border: 1px solid #000;
    position: absolute;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.8);
  }

  .top-left { top: 8px; left: 8px; }
  .top-right { top: 8px; right: 8px; }
  .bottom-left { bottom: 8px; left: 8px; }
  .bottom-right { bottom: 8px; right: 8px; }
</style>