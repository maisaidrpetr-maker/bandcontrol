---
// MetalModule.astro - Centrální komponent pro kovové panely
---
<div class="metal-module-container">
  <div class="rivet top-left"></div>
  <div class="rivet top-right"></div>
  <div class="rivet bottom-left"></div>
  <div class="rivet bottom-right"></div>
  
  <slot /> 
</div>

<style>
  .metal-module-container {
    position: relative;
    background: linear-gradient(135deg, #1a1a1a 0%, #111 100%);
    border-radius: 6px;
    border: 1px solid #2a2a2a;
    padding: 25px;
    box-shadow: 
      0 15px 35px rgba(0,0,0,0.7),
      inset 0 0 100px rgba(0,0,0,0.2);
    margin-bottom: 20px;
  }

  /* POŘÁDNÝ INDUSTRIÁLNÍ NÝT */
  .rivet {
    position: absolute;
    width: 14px; /* Solidní velikost */
    height: 14px;
    /* Efekt broušené oceli s odleskem */
    background: radial-gradient(circle at 35% 35%, #bbb 0%, #555 40%, #222 100%);
    border-radius: 50%;
    /* 1. Stín pod nýtem, 2. Odlesk na horní hraně, 3. Černý okraj (zapuštění) */
    box-shadow: 
      2px 3px 4px rgba(0,0,0,0.6),
      inset 1px 1px 2px rgba(255,255,255,0.4),
      0 0 0 1px #000; 
    z-index: 10;
  }

  /* Pozice nýtů - mírně dál od úplných rohů pro lepší stabilitu */
  .top-left { top: 12px; left: 12px; }
  .top-right { top: 12px; right: 12px; }
  .bottom-left { bottom: 12px; left: 12px; }
  .bottom-right { bottom: 12px; right: 12px; }

  /* Volitelný efekt: Při najetí myší se nýty mírně zalesknou */
  .metal-module-container:hover .rivet {
    filter: brightness(1.2);
    transition: filter 0.3s ease;
  }
</style>