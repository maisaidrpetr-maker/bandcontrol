---
/* src/components/NavigationDrawer.astro */
---

<div id="right-drawer" class="side-drawer collapsed">
  <div class="drawer-handle" id="drawer-toggle">
    <span class="rivet"></span>

    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>

    <span class="rivet"></span>
  </div>

  <div class="drawer-content">
    <div class="nav-group">
      <a href="#" class="btn-nav b-pink active">Board</a>
      <a href="#" class="btn-nav b-orange">Stage</a>
      <a href="#" class="btn-nav b-yellow">BandRoom</a>
      <a href="#" class="btn-nav b-green">Practice</a>
      <a href="#" class="btn-nav b-blue">Library</a>
      <a href="#" class="btn-nav b-purple">Agenda</a>
      <a href="#" class="btn-nav b-magenta">Settings</a>
      <a href="#" class="btn-nav b-cyan">About</a>
    </div>
  </div>
</div>

<script>
  const drawer = document.getElementById('right-drawer');
  const toggle = document.getElementById('drawer-toggle');
  const buttons = document.querySelectorAll('.btn-nav');
  const dots = document.querySelectorAll('.dot');
  const paper = document.querySelector('.content');

  const dotColors = [
    '#FFD1D1', '#FFBFA3', '#FFE7AC', '#C5E9C5', 
    '#BCCBFF', '#CBBCFB', '#ECBCFD', '#BCEBF4'
  ];

  const activateDot = (index) => {
    dots.forEach((d) => {
      d.classList.remove('active');
      d.style.backgroundColor = ''; 
      d.style.boxShadow = '';       
    });
    const activeDot = dots[index];
    if (activeDot) {
      const color = dotColors[index];
      activeDot.classList.add('active');
      activeDot.style.backgroundColor = color;
      activeDot.style.boxShadow = `0 0 10px ${color}, 0 0 20px ${color}`;
    }
  };

  activateDot(0);

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    drawer?.classList.toggle('collapsed');
  });

  paper?.addEventListener('click', () => {
    drawer?.classList.add('collapsed');
  });

  drawer?.addEventListener('click', (e) => e.stopPropagation());

  buttons.forEach((btn, index) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault(); 
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activateDot(index);
      setTimeout(() => {
        drawer?.classList.add('collapsed');
      }, 200); 
    });
  });

  window.addEventListener('DOMContentLoaded', () => {
    setTimeout(() => {
      drawer?.classList.remove('collapsed');
    }, 500);
  });
</script>

<style>
  .side-drawer { 
    position: fixed; right: 0; top: 50%; transform: translateY(-50%); 
    display: flex; align-items: center; z-index: 2000; 
    transition: transform 0.8s cubic-bezier(0.65, 0, 0.35, 1); 
  }
  .side-drawer.collapsed { transform: translateY(-50%) translateX(calc(100% - 40px)); }
  
  .drawer-handle {
    width: 40px;
    height: 240px;
    background: #1a1a1a;
    border: 1px solid #444;
    border-right: none;
    border-radius: 12px 0 0 12px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: center; 
    gap: 8px; 
    align-items: center;
    box-shadow: -10px 0 25px rgba(0,0,0,0.7);
    position: relative;
  }

  /* MASIVNÍ, TEMNÝ KOVOVÝ NÝT */
  .rivet {
    width: 22px; /* Zvětšeno na 22px */
    height: 22px;
    /* Tmavý, tlumený gradient bez bílých odlesků */
    background: radial-gradient(circle at 30% 30%, #777 0%, #444 30%, #222 70%, #111 100%);
    border-radius: 50%;
    border: 1px solid #111;
    /* Dvojitý stín pro hloubku a tlumení */
    box-shadow: 
      0 2px 5px rgba(0,0,0,0.9), 
      inset 0 1px 3px rgba(0,0,0,0.8), /* Zahloubení do plechu */
      inset 0 -1px 2px rgba(255,255,255,0.05); /* Velmi jemný spodní odlesk pro hloubku */
    margin: 15px 0; /* Odsazení od okrajů a LED bloku */
    flex-shrink: 0;
  }

  /* LED KONTROLKY - beze změn */
  .dot {
    width: 8px;
    height: 8px;
    background-color: #444;
    border-radius: 50%;
    transition: all 0.3s ease;
    border: none;
    flex-shrink: 0;
  }

  .dot.active {
    transform: scale(1.3);
  }

  /* OBSAH DRAWERU - beze změn */
  .drawer-content { 
    background: rgba(10, 10, 10, 0.98); padding: 25px; border: 1px solid #333; 
    border-right: none; border-radius: 20px 0 0 20px; box-shadow: -30px 0 60px rgba(0,0,0,1); 
  }

  .nav-group { display: flex; flex-direction: column; gap: 8px; }

  .btn-nav {
    background: linear-gradient(180deg, #333 0%, #151515 100%);
    color: #555;
    border: 1px solid #000;
    width: 150px; height: 42px;
    font-size: 20px; font-weight: 570;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s ease-out;
    cursor: pointer; position: relative; top: 0;
    box-shadow: 0 4px 0 #000, 0 5px 10px rgba(0,0,0,0.5);
    font-family: sans-serif;
  }

  .btn-nav:active, .btn-nav.active {
    top: 3px;
    background: linear-gradient(180deg, #151515 0%, #222 100%);
    box-shadow: 0 1px 0 #000, inset 0 2px 8px rgba(0,0,0,0.8);
  }

  /* BARVY TLAČÍTEK - AKTIVNÍ */
  .b-pink.active    { color: #FFD1D1 !important; text-shadow: 0 0 15px rgba(255, 209, 209, 0.7); }
  .b-orange.active  { color: #FFBFA3 !important; text-shadow: 0 0 15px rgba(255, 191, 163, 0.7); }
  .b-yellow.active  { color: #FFE7AC !important; text-shadow: 0 0 15px rgba(255, 231, 172, 0.7); }
  .b-green.active   { color: #C5E9C5 !important; text-shadow: 0 0 15px rgba(197, 233, 197, 0.7); }
  .b-blue.active    { color: #BCCBFF !important; text-shadow: 0 0 15px rgba(188, 203, 255, 0.7); }
  .b-purple.active  { color: #CBBCFB !important; text-shadow: 0 0 15px rgba(203, 188, 251, 0.7); }
  .b-magenta.active { color: #ECBCFD !important; text-shadow: 0 0 15px rgba(236, 188, 253, 0.7); }
  .b-cyan.active    { color: #BCEBF4 !important; text-shadow: 0 0 15px rgba(188, 235, 244, 0.7); }

  .btn-nav:hover:not(.active) { color: rgba(255, 255, 255, 0.4); }
</style>