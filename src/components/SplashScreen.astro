---
/* src/components/SplashScreen.astro */
---

<div id="splash-container" class="splash-screen">
  <div class="splash-content">
    
    <img src="/images/bms.png" alt="BandControl Logo" class="splash-logo" />

    <div class="blink">
      SYSTEM READY - TAP TO START
    </div>
  </div>
</div>

<script>
  const splash = document.getElementById('splash-container');
  if (splash) {
    splash.addEventListener('click', () => {
      window.location.href = '/dashboard';
    });
  }
</script>

<style>
  .splash-screen {
    position: fixed;
    inset: 0;
    background-color: #000; 
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
  }

  .splash-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .splash-logo {
    max-width: 600px; /* Trochu jsem zvětšil, když nemá okraj */
    width: 90%;
    height: auto;
    margin-bottom: 60px;
    /* Zelená záře přímo na logo */
    filter: drop-shadow(0 0 25px rgba(0, 255, 0, 0.6));
  }

  .blink {
    color: #00f2ff;
    font-family: 'Courier New', Courier, monospace;
    font-weight: bold;
    letter-spacing: 8px;
    font-size: 18px;
    animation: blink-anim 1.5s infinite;
    text-transform: uppercase;
  }

  @keyframes blink-anim { 
    0%, 100% { opacity: 1; text-shadow: 0 0 15px #00f2ff; } 
    50% { opacity: 0.1; text-shadow: none; } 
  }
</style>