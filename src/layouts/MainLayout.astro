---
import '../styles/global.css';
import Header from '../components/Header.astro'; // Importuj tvůj jediný Header
const { title = "BandControl" } = Astro.props;
---
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
</head>
<body>
    <div class="app-shell">
        {/* TADY JE TEN JEDINÝ SPRÁVNÝ HEADER */}
        <Header /> 

        <div class="main-layout">
            <aside class="library">
                <slot name="sidebar-left" />
            </aside>

            <main class="content">
                <div class="paper">
                    <slot />
                </div>
            </main>

            <aside class="sidebar-right"></aside>
            <slot name="sidebar-right" />
        </div>

        <footer class="rack-footer">
    <div class="nav-group">
        <span>BoardControl v. 0.1 - - - Generated by Astro framework.</span>
    </div>
</footer>
    </div>
</body>
</html>