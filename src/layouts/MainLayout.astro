---
import '../styles/global.css';
import Header from '../components/Header.astro'; 
import Footer from '../components/Footer.astro'; // 1. Importuj modul
const { title = "BandControl" } = Astro.props;
---
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
</head>
<body>
    <div class="app-shell">
        <Header /> 

        <div class="main-layout">
            <aside class="library">
                <slot name="sidebar-left" />
            </aside>

            <main class="content">
                <div class="paper">
                    <slot />
                </div>
            </main>

            <aside class="sidebar-right"></aside>
            <slot name="sidebar-right" />
        </div>

        {/* 2. Použij modulární patičku */}
        <Footer />
    </div>
</body>
</html>