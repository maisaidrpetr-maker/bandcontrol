---
import '../styles/global.css';
const { title = "BandControl" } = Astro.props;
---
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
</head>
<body>
    <slot name="splash" />

    <div id="main-app-container" class="app-shell">
        <header class="rack-header">
            <slot name="header" />
        </header>

        <div class="main-layout">
            <aside class="library">
                <slot name="sidebar-left" />
            </aside>

            <main class="content">
                <slot />
            </main>

            <aside class="sidebar-right">
                <slot name="sidebar-right" />
            </aside>
        </div>

        <footer class="rack-footer">
  <div class="nav-group">
    <a href="/board" class="btn-nav">Board</a>
    <a href="/stage" class="btn-nav">Stage</a>
    <a href="/bandroom" class="btn-nav">BandRoom</a>
    <a href="/practice" class="btn-nav">Practice</a>
    <a href="/library" class="btn-nav">Library</a>
    <a href="/agenda" class="btn-nav">Agenda</a>
    <a href="/settings" class="btn-nav">Settings</a>
    <a href="/about" class="btn-nav">About</a>
  </div>
</footer>
    </div>
</body>
</html>