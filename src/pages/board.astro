---
import MainLayout from '../layouts/MainLayout.astro';
import MetalModule from '../components/MetalModule.astro';
import { getCollection, render } from 'astro:content';

const allActivities = await getCollection('activities');
const activities = allActivities.sort((a, b) => 
  new Date(b.data.date.split('.').reverse().join('-')).getTime() - 
  new Date(a.data.date.split('.').reverse().join('-')).getTime()
);
---

<MainLayout title="Board | BandControl">
  <div class="paper-canvas">
    <div class="log-container">
      {activities.map(async (entry) => {
        const { Content } = await render(entry);
        return (
          <article class="log-entry">
            <MetalModule>
              <div class="module-inner">
                <h2>{entry.data.title}</h2>
                <div class="content"><Content /></div>
                <div class="meta">
                  <span>{entry.data.author}</span>
                  <span class="date">{entry.data.date}</span>
                </div>
              </div>
            </MetalModule>
          </article>
        );
      })}
    </div>
  </div>
</MainLayout>

<style>
  .paper-canvas {
    background-color: var(--paper-bg);
    min-height: 100%;
    padding: 60px 40px;
    /* Textura papíru z tvého původního kódu */
    background-image: radial-gradient(#cba46d 0.5px, transparent 0.5px);
    background-size: 24px 24px;
  }

  .log-container {
    display: flex;
    flex-direction: column;
    gap: 30px;
    max-width: 900px;
    margin: 0 auto;
  }

  .module-inner { padding: 20px; }
  .module-inner h2 { font-family: 'Orbitron', sans-serif; color: #fff; margin-bottom: 10px; }
  .meta { display: flex; justify-content: space-between; margin-top: 15px; color: #f80; font-size: 0.8rem; }
</style>