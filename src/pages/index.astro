    // 4. LOGIKA TLAČÍTEK A LAYOUTU
    navButtons.forEach((btn, index) => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            const currentColor = colors[index];

            // A) Změna layoutu (Nalepí 'page-orange', 'page-pink' atd. na body)
            document.body.className = ''; 
            document.body.classList.add(`page-${currentColor}`);

            // B) Aktivace tlačítka v menu
            navButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            // C) Rozsvícení správné tečky na madlu
            dots.forEach((dot, dotIndex) => {
                // Nejdřív zhasneme všechny možné barvy u tečky
                colors.forEach(c => dot.classList.remove(`glow-${c}`));
                // Pokud je to ta správná tečka, rozsvítíme ji aktuální barvou
                if (dotIndex === index) {
                    dot.classList.add(`glow-${currentColor}`);
                }
            });

            // D) Zavření menu po kliknutí (aby byl vidět ten nový layout)
            setTimeout(() => {
                drawer?.classList.add('collapsed');
            }, 700);
        });
    });

    // 5. INICIALIZACE (Aby po startu svítila první tečka - BOARD)
    if (dots[0]) dots[0].classList.add('glow-pink');
</script>
