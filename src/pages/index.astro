---
import '../styles/global.css';
const { pathname } = Astro.url;
---

<html lang="cs">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BandControl | Master</title>
</head>
<body>

    <div id="splash" class="splash-screen">
        <div class="splash-content">
            <img src="/images/bms.png" alt="BMS LOGO" class="splash-logo" />
            <div class="blink">SYSTEM READY - TAP TO START</div>
        </div>
    </div>

    <div class="app-shell" id="app-shell">
        <header class="rack-header">
            <div style="color: #00f2ff; font-family: monospace; font-weight: bold; letter-spacing: 2px;">
                <span style="color: #444;">[</span> UNIT_01 // DASHBOARD <span style="color: #444;">]</span>
            </div>
            <div style="margin-left: auto; color: #555; font-family: monospace; font-size: 11px;">
                BMS_CORE v1.0 // ACTIVE
            </div>
        </header>

        <main class="main-layout">
            <aside class="library">
                <div style="padding: 20px; color: #444; font-family: monospace; font-size: 11px;">
                    > SCANNING...<br/>> OK.
                </div>
            </aside>

            <section class="content">
                <div class="paper">
                    <h1 style="margin-top: 0; letter-spacing: -1px;">CENTRAL BOARD</h1>
                    <div style="height: 2px; background: #000; margin: 25px 0;"></div>
                    <p>Vítej. Navigace je vpravo.</p>
                </div>
            </section>

            <aside class="sidebar-right"></aside>

            <div id="drawer" class="side-drawer collapsed">
                <div id="drawer-handle" class="drawer-handle">
                    <span></span><span></span><span></span>
                </div>
<nav class="drawer-content">
    <a href="#" class="btn-nav b-pink active">BOARD</a>
    <a href="#" class="btn-nav b-orange">STAGE</a>
    <a href="#" class="btn-nav b-yellow">BANDROOM</a>
    <a href="#" class="btn-nav b-green">PRACTICE</a>
    <a href="#" class="btn-nav b-blue">LIBRARY</a>
    <a href="#" class="btn-nav b-purple">AGENDA</a>
    <a href="#" class="btn-nav b-magenta">SETTINGS</a>
    <a href="#" class="btn-nav b-cyan">ABOUT</a>
</nav>
            </div>
        </main>

        <footer class="rack-footer">
            <div style="color: #00f2ff; font-size: 11px; font-family: monospace; text-shadow: 0 0 5px rgba(0,242,255,0.5);">
                ● LIVE_SESSION // 120 BPM // KEY: C#min
            </div>
        </footer>
    </div>

    <script is:inline>
    const splash = document.getElementById('splash');
    const appShell = document.getElementById('app-shell');

    // --- 1. SPLASH SCREEN LOGIC ---
    if (sessionStorage.getItem('bms_init')) {
        splash?.remove();
        if (appShell) appShell.style.visibility = 'visible'; 
    } else {
        if (appShell) appShell.style.visibility = 'hidden'; 
    }

    splash?.addEventListener('click', () => {
        sessionStorage.setItem('bms_init', 'true');
        splash.style.opacity = '0';
        
        setTimeout(() => {
            splash.remove();
            if (appShell) {
                appShell.style.visibility = 'visible'; 
            }
        }, 800);
    });

    // --- 2. DRAWER (ŠUPLÍK) LOGIC ---
    const drawer = document.getElementById('drawer');
    const handle = document.getElementById('drawer-handle');
    
    handle?.addEventListener('click', () => {
        drawer.classList.toggle('collapsed');
    });

    document.querySelector('.content')?.addEventListener('click', () => {
        drawer?.classList.add('collapsed');
    });

    // --- 3. TLAČÍTKA (BARVY A AUTOMATICKÉ ZAVÍRÁNÍ) ---
    const navButtons = document.querySelectorAll('.btn-nav');

    navButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
            // VŽDYCKY zastavíme původní akci, aby se stránka neobnovila hned
            e.preventDefault();

            // 1. Rozsvítíme barvu
            navButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            // 2. Počkáme na ten tvůj hardware moment (700ms)
            setTimeout(() => {
                drawer?.classList.add('collapsed');
                
                // Pokud bys později chtěl, aby BOARD opravdu někam skočil:
                // window.location.href = btn.getAttribute('href');
            }, 700); 
        });
    });
</script>
</body>
</html>