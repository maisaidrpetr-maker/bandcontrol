---
import '../styles/global.css';
const { pathname } = Astro.url;
---

<html lang="cs">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BandControl | Master</title>
</head>
<body>

    <div id="splash" class="splash-screen">
        <div class="splash-content">
            <img src="/images/bms.png" alt="BMS LOGO" class="splash-logo" />
            <div class="blink">SYSTEM READY - TAP TO START</div>
        </div>
    </div>

    <div class="app-shell">
        <header class="rack-header">
            <div style="color: #00f2ff; font-family: monospace; font-weight: bold; letter-spacing: 2px;">
                <span style="color: #444;">[</span> UNIT_01 // DASHBOARD <span style="color: #444;">]</span>
            </div>
            <div style="margin-left: auto; color: #555; font-family: monospace; font-size: 11px;">
                BMS_CORE v1.0 // ACTIVE
            </div>
        </header>

        <main class="main-layout">
            <aside class="library">
                <div style="padding: 20px; color: #444; font-family: monospace; font-size: 11px;">
                    > SCANNING_STORAGE...<br/>
                    > OK.
                </div>
            </aside>

            <section class="content">
                <div class="paper">
                    <h1 style="margin-top: 0; letter-spacing: -1px;">CENTRAL BOARD</h1>
                    <div style="height: 2px; background: #000; margin: 25px 0;"></div>
                    <p>Systém je připraven. Navigace sekcí je dostupná ve vysouvacím panelu napravo.</p>
                </div>
            </section>

            <aside class="sidebar-right"></aside>

            <div id="drawer" class="side-drawer collapsed">
                <div id="drawer-handle" class="drawer-handle">
                    <span></span><span></span><span></span>
                </div>
                <nav class="drawer-content">
                    <a href="/" class={pathname === '/' ? 'btn-nav active' : 'btn-nav'}>BOARD</a>
                    <a href="#" class="btn-nav">STAGE</a>
                    <a href="#" class="btn-nav">BANDROOM</a>
                    <a href="#" class="btn-nav">PRACTICE</a>
                    <a href="#" class="btn-nav">LIBRARY</a>
                    <a href="#" class="btn-nav">AGENDA</a>
                    <a href="#" class="btn-nav">SETTINGS</a>
                    <a href="#" class="btn-nav">ABOUT</a>
                </nav>
            </div>
        </main>

        <footer class="rack-footer">
            <div style="color: #00f2ff; font-size: 11px; font-family: monospace; text-shadow: 0 0 5px rgba(0,242,255,0.5);">
                ● LIVE_SESSION // 120 BPM // KEY: C#min
            </div>
        </footer>
    </div>

    <script is:inline>
        // Splash logic
        const splash = document.getElementById('splash');
        if (sessionStorage.getItem('bms_init')) {
            splash?.remove();
        }
        splash?.addEventListener('click', () => {
            sessionStorage.setItem('bms_init', 'true');
            splash.style.opacity = '0';
            setTimeout(() => splash.remove(), 600);
        });

        // Drawer logic
        const drawer = document.getElementById('drawer');
        const handle = document.getElementById('drawer-handle');
        handle?.addEventListener('click', () => {
            drawer.classList.toggle('collapsed');
        });

        // Zavření šuplíku kliknutím na papír
        document.querySelector('.content')?.addEventListener('click', () => {
            drawer?.classList.add('collapsed');
        });
    </script>
</body>
</html>