---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allSongs = await getCollection('songs');
  return allSongs.map(song => ({
    params: { slug: song.id },
    props: { song },
  }));
}

const { song } = Astro.props;

function parseChordProLine(line) {
  let chords = "";
  let lyrics = "";
  const parts = line.split(/\[(.*?)\]/g);
  
  for (let i = 0; i < parts.length; i++) {
    if (i % 2 === 1) {
      chords = chords.padEnd(lyrics.length) + parts[i];
    } else {
      lyrics += parts[i];
    }
  }
  return { chords, lyrics };
}

const lines = song.body.split('\n');
---

<MainLayout title={`${song.data.title} | LIVE`}>
  <div class="paper">
    <div class="chord-content">
      <div class="song-render">
        {lines.map(line => {
          if (line.startsWith('{')) {
            const content = line.replace(/[{}]/g, '').split(':').pop().trim();
            return <div class="comment">{content}</div>;
          }
          
          const { chords, lyrics } = parseChordProLine(line);
          
          return (
            <div class="line-group">
              {/* Pokud řádek s akordy existuje, vykreslíme ho */}
              {chords.trim() ? <div class="chords-line">{chords}</div> : null}
              <div class="lyrics-line">{lyrics || "\u00A0"}</div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</MainLayout>

<style is:global>
  .paper {
    background-color: #fdf6e3 !important;
    min-height: 100vh;
    width: 100%;
  }

  .chord-content {
    padding: 40px 60px;
  }

  .song-render {
    font-family: 'Courier New', Courier, monospace !important;
    font-size: 1.4rem;
    color: #1a1a1a;
  }

  .line-group {
    display: flex;
    flex-direction: column;
    /* MEZERA MEZI CELÝMI ŘÁDKY (ODSTUP SLOK) */
    margin-bottom: 0.6rem; 
  }

  .chords-line {
    white-space: pre;
    color: #c53030;
    font-weight: bold;
    line-height: 1;
    /* PŘITAŽENÍ AKORDU DOLŮ K TEXTU */
    /* Čím větší záporné číslo (např. -0.6rem), tím blíž textu budou */
    margin-bottom: -0.2rem; 
  }

  .lyrics-line {
    white-space: pre;
    line-height: 1;
  }

  .comment {
    color: #718096;
    font-style: italic;
    margin-bottom: 1.2rem;
    font-weight: bold;
  }
</style>