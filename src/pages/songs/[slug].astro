---
import MainLayout from '../../layouts/MainLayout.astro';
import ChordSheetJS from 'chordsheetjs';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allSongs = await getCollection('songs');
  return allSongs.map(song => ({
    params: { slug: song.id },
    props: { song },
  }));
}

const { song } = Astro.props;

const parser = new ChordSheetJS.ChordProParser();
const chordSheet = parser.parse(song.body);

const formatter = new ChordSheetJS.TextFormatter();
const plainText = formatter.format(chordSheet);
---

<MainLayout title={`${song.data.title} | LIVE`}>
    <div class="paper">
        <div class="chord-content">
            <pre class="song-render">{plainText}</pre>
        </div>
    </div>
</MainLayout>

<style is:global>
    .paper {
        background-color: #fdf6e3 !important;
        min-height: 100vh;
        width: 100%;
        display: block;
    }

    .chord-content {
        padding: 40px 60px;
    }

    .song-render {
        font-family: 'Courier New', Courier, monospace !important;
        font-size: 1.4rem;
        
        /* Zvýšeno na 1.8: 
           Tím se zvětší mezera pod každým řádkem. 
           Vizuálně to vytvoří přesně ten odstup pod textem před dalším akordem. */
        line-height: 1.8 !important; 
        
        white-space: pre;
        color: #1a1a1a;
        margin: 0;
    }
</style>